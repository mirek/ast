{
  "name": "@mirek/ast",
  "version": "0.0.0",
  "private": true,
  "description": "Typed node-graph queries and change planning for heterogeneous resources.",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/ast.git",
    "directory": "packages/core"
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "pnpm run build && node --test test/*.test.mjs",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "typescript": "5.9.3"
  }
}
