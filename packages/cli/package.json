{
  "name": "@mirek/ast-cli",
  "version": "0.0.0",
  "private": true,
  "description": "Command-line boundary for @mirek/ast.",
  "type": "module",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "ast": "./dist/bin.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/ast.git",
    "directory": "packages/cli"
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "pnpm run build && node --test test/*.test.mjs",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "@mirek/ast": "workspace:*"
  }
}
